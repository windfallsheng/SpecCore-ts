#!/bin/bash
# pre-commit - Git Pre-commit Hook
# 安装方式：ln -sf ../../scripts/git-hooks/pre-commit .git/hooks/pre-commit
# 检查修改的代码文件是否包含 @spec 注释，若没有则警告（不强制）

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

print_warning() { echo -e "${YELLOW}⚠️  $1${NC}"; }
print_error() { echo -e "${RED}❌ $1${NC}"; }
print_success() { echo -e "${GREEN}✅ $1${NC}"; }

echo ""
echo "🔍 Spec 注释检查..."

# 获取本次提交修改的代码文件
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(java|kt|ts|js|vue|go|py)$' || true)

if [ -z "$CHANGED_FILES" ]; then
    print_success "未检测到代码文件变更，跳过检查"
    exit 0
fi

MISSING_SPEC=()
HAS_SPEC=()

for FILE in $CHANGED_FILES; do
    if grep -q "@spec" "$FILE" 2>/dev/null; then
        HAS_SPEC+=("$FILE")
    else
        MISSING_SPEC+=("$FILE")
    fi
done

echo ""
echo "📊 检查结果："
echo "  ✅ 包含 @spec 注释：${#HAS_SPEC[@]} 个文件"
echo "  ⚠️  缺少 @spec 注释：${#MISSING_SPEC[@]} 个文件"

if [ ${#MISSING_SPEC[@]} -gt 0 ]; then
    echo ""
    print_warning "以下文件缺少 @spec 注释："
    for FILE in "${MISSING_SPEC[@]}"; do
        echo "    - $FILE"
    done
    echo ""
    echo "💡 建议：在文件头部添加 @spec 注释，格式如下："
    echo ""
    echo "   /**"
    echo "    * @spec Task-XXX"
    echo "    * @spec-link 期次-XXX/Task-XXX/REQ.md"
    echo "    * @spec-title {任务名称}"
    echo "    * @spec-type backend"
    echo "    * @generated-by SpecCore v3.0.0"
    echo "    */"
    echo ""
    echo "⚠️  这只是一个警告，不会阻止提交。"
    echo "   如需强制检查，请设置环境变量 SPEC_STRICT=true"
    echo ""
fi

# 如设置严格模式，则阻断提交
if [ "${SPEC_STRICT:-false}" = "true" ] && [ ${#MISSING_SPEC[@]} -gt 0 ]; then
    print_error "严格模式已开启，缺少 @spec 注释，提交被阻断"
    exit 1
fi

print_success "检查完成"
exit 0
