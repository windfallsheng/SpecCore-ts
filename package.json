{
  "name": "speccore",
  "version": "5.13.0",
  "description": "SpecCore - Code by Spec, Not by Vibe.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "speccore": "./bin/speccore"
  },
  "scripts": {
    "build": "tsc && cp -r src/locales dist/",
    "watch": "tsc --watch",
    "prepublish": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "spec-driven-development",
    "ai",
    "cli",
    "code-generation",
    "spec"
  ],
  "author": "SpecCore Team <windfallsheng@aliyun.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/windfallsheng/SpecCore-ts"
  },
  "files": [
    "dist",
    "bin"
  ],
  "dependencies": {
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^14.0.2",
    "js-yaml": "^4.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.5",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^5.3.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
